{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create build folder",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "md",
        "-Force",
        "build",
      ],
      "options": {"cwd": "${workspaceFolder}"},
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "uv: sync",
      "type": "shell",
      "command": "uv",
      "args": [
        "sync",
      ],
      "options": {"cwd": "${workspaceFolder}"},
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "dependsOn": "Create build folder",
      "problemMatcher": []
    },
    {
      "label": "Conan: install",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        // `-s   build_type=Release` sets the overall build type for the dependencies.
        // `-s &:build_type=Release` sets the build type for this project's source code.
        "& '../.venv/Scripts/conan.exe' install .. --build=missing -s build_type=Release -s `&:build_type=Debug -c tools.env.virtualenv:powershell=powershell.exe -c tools.env:dotenv=true"
      ],
      "options": {
        "cwd": "${workspaceFolder}/build",
        "env": {
          "Path": "${workspaceFolder}\\.venv\\Scripts;${env:Path}"
        }
      },
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "dependsOn": ["uv: sync"],
      "problemMatcher": []
    },
    {
      "label": "CMake: configure conan-default",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\cmake",
      "args": ["--preset", "conan-default",
               "-DCMAKE_CONFIGURATION_TYPES=Debug" // Explicitly set here because Conan forgets to set this cache variable for MSVC.
            ],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": [],
      "dependsOn": "Conan: install",
    },
    {
      "label": "CMake: build conan (debug)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\cmake",
      "args": ["--build", "--preset", "conan-debug"],
      "dependsOn": "CMake: configure conan-default",
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
  ]
}
