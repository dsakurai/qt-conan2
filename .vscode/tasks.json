{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Create build folder",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "md",
        "-Force",
        "build",
      ],
      "options": {"cwd": "${workspaceFolder}"},
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "uv: sync",
      "type": "shell",
      "command": "uv",
      "args": [
        "sync",
      ],
      "options": {"cwd": "${workspaceFolder}"},
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "dependsOn": "Create build folder",
      "problemMatcher": []
    },
    {
      "label": "Conan: install",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "& '../.venv/Scripts/conan.exe' install .. --build=missing -s build_type=Debug -c tools.env.virtualenv:powershell=powershell.exe "
      ],
      "options": {
        "cwd": "${workspaceFolder}/build",
        "env": {
          "Path": "${workspaceFolder}\\.venv\\Scripts;${env:Path}"
        }
      },
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "dependsOn": ["uv: sync"],
      "problemMatcher": []
    },
    {
      "label": "Export: conan env to .env",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/export_conan_env.ps1",
        "${workspaceFolder}/build/generators/conan.env"
      ],
      "dependsOn": "Conan: install",
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: configure conan-default",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\cmake",
      "args": ["--preset", "conan-default"],
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": [],
      "dependsOn": "Export: conan env to .env",
    },
    {
      "label": "CMake: build conan (debug)",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\cmake",
      "args": ["--build", "--preset", "conan-debug"],
      "dependsOn": "CMake: configure conan-default",
      "group": { "kind": "build", "isDefault": true },
      "presentation": {
        "reveal": "silent",
        "echo": true,
        "panel": "shared"
      },
      "problemMatcher": []
    },
  ]
}
